{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI BeatSync Studio",
  "version": "0.1.0",
  "identifier": "com.beatsync.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI BeatSync Studio",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["bin/ffmpeg.exe", "bin/ffprobe.exe"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
